PORT=3000

# Production URL (set to your Vercel domain in production)
APP_URL=http://localhost:3000

# Where the SQLite database is stored. Leave unset locally (defaults to ./data).
# In production (Railway), set this to a mounted volume path (e.g. /data) so the
# database survives deploys instead of being wiped on every restart.
DATA_DIR=

# Supabase (Settings → API in your Supabase project)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Claude API
ANTHROPIC_API_KEY=

# Twitter / X (OAuth 2.0)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# LinkedIn (OAuth 2.0)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Substack (for links only — no API)
SUBSTACK_URL=
