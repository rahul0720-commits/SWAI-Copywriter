<%- include('partials/head', { title: 'Dashboard' }) %>

<!-- Page header -->
<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:32px;">
  <div>
    <h1 style="font-family:'Inter',sans-serif; font-size:28px; font-weight:700; color:#1f1b17; letter-spacing:-0.02em; margin:0;">Distribution Copy</h1>
    <p style="font-family:'Inter',sans-serif; font-size:15px; color:#777587; margin:4px 0 0;">Upload a transcript and generate content for each podcast.</p>
  </div>
  <button onclick="toggleUploadForm()" id="new-episode-btn" style="display:flex;align-items:center;gap:8px;background:#ba4b1d;color:#fff;border:none;padding:10px 18px;border-radius:6px;font-family:'Inter',sans-serif;font-size:14px;font-weight:600;cursor:pointer;transition:background 0.15s;" onmouseover="this.style.background='#8c3213'" onmouseout="this.style.background='#ba4b1d'">
    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>
    New Distribution Copy
  </button>
</div>

<!-- Upload form (hidden by default) -->
<div id="upload-form-panel" style="display:none; margin-bottom:28px;">
  <div style="background:#ffffff; border:1px solid #c7c4d8; border-radius:8px; padding:28px;">
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
      <h2 style="font-family:'Inter',sans-serif; font-size:16px; font-weight:600; color:#1f1b17; margin:0;">New Distribution Copy</h2>
      <button onclick="toggleUploadForm()" style="background:none;border:none;cursor:pointer;color:#777587;padding:4px;">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </div>
    <form action="/episodes" method="POST" enctype="multipart/form-data">
      <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:16px; margin-bottom:16px;">
        <div>
          <label style="display:block;font-size:13px;font-weight:500;color:#464555;margin-bottom:6px;">Distribution Copy Title <span style="color:#ba1a1a;">*</span></label>
          <input type="text" name="title" required style="width:100%;padding:8px 12px;border:1px solid #c7c4d8;border-radius:6px;font-size:14px;color:#1f1b17;background:#fff;box-sizing:border-box;">
        </div>
        <div>
          <label style="display:block;font-size:13px;font-weight:500;color:#464555;margin-bottom:6px;">Guest Name</label>
          <input type="text" name="guest_name" style="width:100%;padding:8px 12px;border:1px solid #c7c4d8;border-radius:6px;font-size:14px;color:#1f1b17;background:#fff;box-sizing:border-box;">
        </div>
        <div>
          <label style="display:block;font-size:13px;font-weight:500;color:#464555;margin-bottom:6px;">Recording Date</label>
          <input type="date" name="recording_date" style="width:100%;padding:8px 12px;border:1px solid #c7c4d8;border-radius:6px;font-size:14px;color:#1f1b17;background:#fff;box-sizing:border-box;">
        </div>
      </div>
      <div style="margin-bottom:20px;">
        <label style="display:block;font-size:13px;font-weight:500;color:#464555;margin-bottom:6px;">Transcript File <span style="color:#777587;">(SRT or TXT)</span> <span style="color:#ba1a1a;">*</span></label>
        <div style="border:2px dashed #c7c4d8;border-radius:6px;padding:20px;text-align:center;background:#fcf2eb;position:relative;">
          <svg width="24" height="24" fill="none" stroke="#777587" stroke-width="1.5" viewBox="0 0 24 24" style="margin:0 auto 8px;"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
          <p style="font-size:13px;color:#464555;margin:0 0 8px;font-family:'Inter',sans-serif;">Drop file here or click to browse</p>
          <input type="file" name="transcript" accept=".srt,.txt" required style="position:absolute;inset:0;width:100%;height:100%;opacity:0;cursor:pointer;">
          <span id="file-name" style="font-size:12px;color:#777587;font-family:'Inter',sans-serif;">No file chosen</span>
        </div>
      </div>
      <div style="display:flex;gap:10px;">
        <button type="submit" style="background:#ba4b1d;color:#fff;border:none;padding:10px 20px;border-radius:6px;font-family:'Inter',sans-serif;font-size:14px;font-weight:600;cursor:pointer;">Upload &amp; Continue →</button>
        <button type="button" onclick="toggleUploadForm()" style="background:none;color:#464555;border:1px solid #c7c4d8;padding:10px 16px;border-radius:6px;font-family:'Inter',sans-serif;font-size:14px;font-weight:500;cursor:pointer;">Cancel</button>
      </div>
    </form>
  </div>
</div>

<!-- Episode list -->
<% if (episodes.length === 0) { %>
  <div style="text-align:center;padding:80px 0;background:#ffffff;border:1px solid #c7c4d8;border-radius:8px;">
    <svg width="40" height="40" fill="none" stroke="#c7c4d8" stroke-width="1.5" viewBox="0 0 24 24" style="margin:0 auto 16px;"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
    <p style="font-family:'Inter',sans-serif;font-size:15px;color:#777587;margin:0 0 6px;">No distribution copies yet</p>
    <p style="font-family:'Inter',sans-serif;font-size:13px;color:#c7c4d8;margin:0;">Click "New Distribution Copy" above to get started.</p>
  </div>
<% } else { %>

  <!-- Column headers -->
  <div style="display:grid;grid-template-columns:1fr 160px 160px 120px;gap:16px;padding:0 16px 10px;align-items:center;">
    <span style="font-size:12px;font-weight:600;color:#777587;letter-spacing:0.04em;text-transform:uppercase;">Distribution Copy</span>
    <span style="font-size:12px;font-weight:600;color:#777587;letter-spacing:0.04em;text-transform:uppercase;">Guest</span>
    <span style="font-size:12px;font-weight:600;color:#777587;letter-spacing:0.04em;text-transform:uppercase;">Date</span>
    <span style="font-size:12px;font-weight:600;color:#777587;letter-spacing:0.04em;text-transform:uppercase;">Status</span>
  </div>

  <div style="display:flex;flex-direction:column;gap:6px;">
    <% episodes.forEach(ep => { %>
      <%
        const hasContent = ep.blog_post || ep.twitter_thread || ep.linkedin_post;
        const allApproved = ep.blog_approved && ep.twitter_approved && ep.linkedin_approved;
        const published = ep.twitter_published || ep.linkedin_published;
        let statusLabel, statusColor, statusBg, statusDot;
        if (published) {
          statusLabel = 'Published'; statusColor = '#8c3213'; statusBg = '#fde8d6'; statusDot = '#ba4b1d';
        } else if (allApproved) {
          statusLabel = 'Approved'; statusColor = '#065f46'; statusBg = '#d1fae5'; statusDot = '#059669';
        } else if (hasContent) {
          statusLabel = 'In Review'; statusColor = '#92400e'; statusBg = '#fef3c7'; statusDot = '#d97706';
        } else {
          statusLabel = 'Uploaded'; statusColor = '#1e40af'; statusBg = '#dbeafe'; statusDot = '#3b82f6';
        }
      %>
      <div style="background:#ffffff;border:1px solid #c7c4d8;border-radius:8px;padding:16px;display:grid;grid-template-columns:1fr 160px 160px 120px;gap:16px;align-items:center;transition:border-color 0.15s;" onmouseover="this.style.borderColor='#ba4b1d'" onmouseout="this.style.borderColor='#c7c4d8'">
        <div>
          <a href="/episodes/<%= ep.id %>/review" style="font-family:'Inter',sans-serif;font-size:15px;font-weight:600;color:#1f1b17;text-decoration:none;" onmouseover="this.style.color='#ba4b1d'" onmouseout="this.style.color='#1f1b17'">
            <%= ep.title %>
          </a>
        </div>
        <div style="font-family:'Inter',sans-serif;font-size:14px;color:#464555;">
          <%= ep.guest_name || '—' %>
        </div>
        <div style="font-family:'Inter',sans-serif;font-size:14px;color:#777587;">
          <%= new Date(ep.created_at).toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' }) %>
        </div>
        <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;">
          <span style="display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:500;color:<%= statusColor %>;background:<%= statusBg %>;padding:4px 10px;border-radius:99px;">
            <span style="width:7px;height:7px;border-radius:50%;background:<%= statusDot %>;flex-shrink:0;"></span>
            <%= statusLabel %>
          </span>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>

<script>
function toggleUploadForm() {
  const panel = document.getElementById('upload-form-panel');
  const isHidden = panel.style.display === 'none';
  panel.style.display = isHidden ? 'block' : 'none';
  if (isHidden) panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

// Show file name in upload zone
document.querySelector('input[type="file"]')?.addEventListener('change', function() {
  document.getElementById('file-name').textContent = this.files[0]?.name || 'No file chosen';
});
</script>

<%- include('partials/foot') %>
