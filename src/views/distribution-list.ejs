<%- include('partials/head', { title: 'Distribution' }) %>

<!-- Page header -->
<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:32px;gap:16px;flex-wrap:wrap;">
  <div>
    <h1 style="font-family:'Inter',sans-serif;font-size:28px;font-weight:700;color:#1f1b17;letter-spacing:-0.02em;margin:0;">Distribution</h1>
    <p style="font-family:'Inter',sans-serif;font-size:15px;color:#777587;margin:4px 0 0;">Upload a final transcript to generate distribution copy — fresh, or edited outside the tool.</p>
  </div>
  <% if (recordings.length > 0) { %>
  <button onclick="toggleNewForm()" style="display:flex;align-items:center;gap:8px;background:#ba4b1d;color:#fff;border:none;padding:10px 18px;border-radius:6px;font-family:'Inter',sans-serif;font-size:14px;font-weight:600;cursor:pointer;white-space:nowrap;">
    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>
    Start Distribution
  </button>
  <% } %>
</div>

<!-- Start Distribution form (hidden by default) -->
<div id="new-form-panel" style="display:none;margin-bottom:28px;">
  <div style="background:#ffffff;border:1px solid #c7c4d8;border-radius:8px;padding:28px;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
      <h2 style="font-family:'Inter',sans-serif;font-size:16px;font-weight:600;color:#1f1b17;margin:0;">Start Distribution</h2>
      <button onclick="toggleNewForm()" style="background:none;border:none;cursor:pointer;color:#777587;padding:4px;">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </div>
    <p style="font-family:'Inter',sans-serif;font-size:13px;color:#777587;margin:0 0 18px;">Upload the <strong>final</strong> transcript (the edit you're distributing from). To pull an in-tool edit instead, use “Send to Distribution” at the end of the Content Editor.</p>
    <form action="/distribution" method="POST" enctype="multipart/form-data">
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;margin-bottom:16px;" class="form-grid-3">
        <div>
          <label style="display:block;font-size:13px;font-weight:500;color:#464555;margin-bottom:6px;">Title <span style="color:#ba1a1a;">*</span></label>
          <input type="text" name="title" required placeholder="e.g. Rahul & John on shipping fast" style="width:100%;padding:8px 12px;border:1px solid #c7c4d8;border-radius:6px;font-size:14px;color:#1f1b17;background:#fff;box-sizing:border-box;">
        </div>
        <div>
          <label style="display:block;font-size:13px;font-weight:500;color:#464555;margin-bottom:6px;">Guest Name</label>
          <input type="text" name="guest_name" placeholder="e.g. John Doe" style="width:100%;padding:8px 12px;border:1px solid #c7c4d8;border-radius:6px;font-size:14px;color:#1f1b17;background:#fff;box-sizing:border-box;">
        </div>
        <div>
          <label style="display:block;font-size:13px;font-weight:500;color:#464555;margin-bottom:6px;">Recording Date</label>
          <input type="date" name="recording_date" style="width:100%;padding:8px 12px;border:1px solid #c7c4d8;border-radius:6px;font-size:14px;color:#1f1b17;background:#fff;box-sizing:border-box;">
        </div>
      </div>
      <div style="margin-bottom:20px;">
        <label style="display:block;font-size:13px;font-weight:500;color:#464555;margin-bottom:6px;">Final Transcript <span style="color:#777587;">(SRT or TXT)</span></label>
        <div style="border:2px dashed #c7c4d8;border-radius:6px;padding:16px;text-align:center;background:#fcf2eb;position:relative;">
          <svg width="20" height="20" fill="none" stroke="#777587" stroke-width="1.5" viewBox="0 0 24 24" style="margin:0 auto 6px;"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
          <p style="font-size:13px;color:#464555;margin:0 0 4px;font-family:'Inter',sans-serif;">Drop file here or click to browse</p>
          <input type="file" name="transcript" accept=".srt,.txt" style="position:absolute;inset:0;width:100%;height:100%;opacity:0;cursor:pointer;" id="transcript-input">
          <span id="transcript-name" style="font-size:12px;color:#777587;font-family:'Inter',sans-serif;">No file chosen</span>
        </div>
      </div>
      <div style="display:flex;gap:10px;">
        <button type="submit" style="background:#ba4b1d;color:#fff;border:none;padding:10px 20px;border-radius:6px;font-family:'Inter',sans-serif;font-size:14px;font-weight:600;cursor:pointer;">Start Distribution →</button>
        <button type="button" onclick="toggleNewForm()" style="background:none;color:#464555;border:1px solid #c7c4d8;padding:10px 16px;border-radius:6px;font-family:'Inter',sans-serif;font-size:14px;font-weight:500;cursor:pointer;">Cancel</button>
      </div>
    </form>
  </div>
</div>

<% if (recordings.length === 0) { %>
  <div id="empty-state" style="text-align:center;padding:72px 24px;background:#ffffff;border:1px solid #c7c4d8;border-radius:8px;">
    <svg width="40" height="40" fill="none" stroke="#c7c4d8" stroke-width="1.5" viewBox="0 0 24 24" style="margin:0 auto 16px;"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
    <p style="font-family:'Inter',sans-serif;font-size:16px;font-weight:600;color:#1f1b17;margin:0 0 6px;">Nothing in distribution yet</p>
    <p style="font-family:'Inter',sans-serif;font-size:14px;color:#777587;margin:0 0 20px;max-width:440px;margin-left:auto;margin-right:auto;">Upload a final transcript to generate distribution copy — or send an edit over from the Content Editor.</p>
    <button onclick="toggleNewForm()" style="display:inline-flex;align-items:center;gap:8px;background:#ba4b1d;color:#fff;border:none;padding:11px 22px;border-radius:6px;font-family:'Inter',sans-serif;font-size:14px;font-weight:600;cursor:pointer;">
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>
      Start Distribution
    </button>
  </div>
<% } else { %>

  <!-- Column headers -->
  <div style="display:grid;grid-template-columns:1fr 140px 130px 130px 110px;gap:12px;padding:0 16px 10px;align-items:center;" class="dist-header">
    <span style="font-size:12px;font-weight:600;color:#777587;letter-spacing:0.04em;text-transform:uppercase;">Episode</span>
    <span style="font-size:12px;font-weight:600;color:#777587;letter-spacing:0.04em;text-transform:uppercase;">Guest</span>
    <span style="font-size:12px;font-weight:600;color:#777587;letter-spacing:0.04em;text-transform:uppercase;">Date</span>
    <span style="font-size:12px;font-weight:600;color:#777587;letter-spacing:0.04em;text-transform:uppercase;text-align:center;">Generated</span>
    <span style="font-size:12px;font-weight:600;color:#777587;letter-spacing:0.04em;text-transform:uppercase;text-align:center;">Approved</span>
  </div>

  <div style="display:flex;flex-direction:column;gap:6px;">
    <% recordings.forEach(rec => {
      const allApproved = rec.approved === rec.total;
      const someGen = rec.generated > 0;
    %>
      <a href="/recordings/<%= rec.id %>/distribution" style="background:#ffffff;border:1px solid #c7c4d8;border-radius:8px;padding:16px;display:grid;grid-template-columns:1fr 140px 130px 130px 110px;gap:12px;align-items:center;text-decoration:none;transition:border-color 0.15s;" onmouseover="this.style.borderColor='#ba4b1d'" onmouseout="this.style.borderColor='#c7c4d8'" class="dist-row">
        <div style="min-width:0;">
          <div style="font-family:'Inter',sans-serif;font-size:15px;font-weight:600;color:#1f1b17;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= rec.title %></div>
        </div>
        <div style="font-family:'Inter',sans-serif;font-size:13px;color:#464555;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= rec.guest_name || '—' %></div>
        <div style="font-family:'Inter',sans-serif;font-size:13px;color:#777587;white-space:nowrap;">
          <%= rec.created_at ? new Date(rec.created_at).toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' }) : '—' %>
        </div>
        <div style="text-align:center;">
          <span style="display:inline-flex;align-items:center;gap:4px;font-size:12px;font-weight:500;color:<%= someGen ? '#065f46' : '#777587' %>;background:<%= someGen ? '#d1fae5' : '#f0e6e0' %>;padding:3px 10px;border-radius:99px;">
            <span style="width:6px;height:6px;border-radius:50%;background:<%= someGen ? '#059669' : '#c7c4d8' %>;flex-shrink:0;"></span><%= rec.generated %>/<%= rec.total %>
          </span>
        </div>
        <div style="text-align:center;">
          <span style="display:inline-flex;align-items:center;gap:4px;font-size:12px;font-weight:500;color:<%= allApproved ? '#065f46' : '#777587' %>;background:<%= allApproved ? '#d1fae5' : '#f0e6e0' %>;padding:3px 10px;border-radius:99px;">
            <span style="width:6px;height:6px;border-radius:50%;background:<%= allApproved ? '#059669' : '#c7c4d8' %>;flex-shrink:0;"></span><%= rec.approved %>/<%= rec.total %>
          </span>
        </div>
      </a>
    <% }); %>
  </div>
<% } %>

<style>
@media (max-width: 768px) {
  .form-grid-3 { grid-template-columns: 1fr !important; }
  .dist-header { display: none !important; }
  .dist-row { grid-template-columns: 1fr !important; gap: 8px !important; }
}
</style>

<script>
function toggleNewForm() {
  const panel = document.getElementById('new-form-panel');
  const isHidden = panel.style.display === 'none';
  panel.style.display = isHidden ? 'block' : 'none';
  const empty = document.getElementById('empty-state');
  if (empty) empty.style.display = isHidden ? 'none' : '';
  if (isHidden) panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

document.getElementById('transcript-input')?.addEventListener('change', function() {
  document.getElementById('transcript-name').textContent = this.files[0]?.name || 'No file chosen';
});
</script>

<%- include('partials/foot') %>
