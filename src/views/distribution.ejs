<%- include('partials/head', { title: title }) %>

<!-- Loading overlay -->
<div id="loading-overlay" class="loading-overlay" style="display:none;">
  <div class="spinner"></div>
  <p style="font-family:'Inter',sans-serif;font-size:16px;font-weight:600;color:#1f1b17;margin:0;">Generating content…</p>
  <p style="font-family:'Inter',sans-serif;font-size:14px;color:#777587;margin:0;">Claude is writing from the final transcript. This can take up to a minute.</p>
</div>

<!-- Back -->
<div style="margin-bottom:20px;">
  <a href="/recordings" style="display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:500;color:#777587;text-decoration:none;" onmouseover="this.style.color='#ba4b1d'" onmouseout="this.style.color='#777587'">
    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
    All Recordings
  </a>
</div>

<!-- Header + stage tabs -->
<div style="margin-bottom:28px;">
  <h1 style="font-family:'Space Grotesk',sans-serif;font-size:24px;font-weight:700;color:#1f1b17;letter-spacing:-0.02em;margin:0 0 4px;"><%= recording.title %></h1>
  <p style="font-family:'Inter',sans-serif;font-size:14px;color:#777587;margin:0 0 20px;">
    <% if (recording.guest_name) { %>with <%= recording.guest_name %> &middot; <% } %>
    <%= recording.created_at ? new Date(recording.created_at).toLocaleDateString('en-US', { month:'long', day:'numeric', year:'numeric' }) : '' %>
  </p>
  <%- include('partials/recording-nav', { recording: recording, active: 'distribution' }) %>
</div>

<% if (!episode || !episode.transcript_clean) { %>
<!-- ── No final transcript yet: upload ──────────────────────────────────────── -->
<div style="background:#ffffff;border:1px solid #c7c4d8;border-radius:8px;padding:40px;max-width:600px;">
  <div style="width:48px;height:48px;border-radius:12px;background:#fde8d6;display:flex;align-items:center;justify-content:center;margin-bottom:20px;">
    <svg width="24" height="24" fill="none" stroke="#ba4b1d" stroke-width="1.5" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
  </div>
  <h2 style="font-family:'Space Grotesk',sans-serif;font-size:18px;font-weight:700;color:#1f1b17;margin:0 0 8px;">Upload final transcript</h2>
  <p style="font-family:'Inter',sans-serif;font-size:14px;color:#777587;margin:0 0 24px;">Distribution copy is written from the final edited transcript. This is separate from the raw recording transcript used for the intro and Content Editor.</p>

  <form action="/recordings/<%= recording.id %>/distribution/create" method="POST" enctype="multipart/form-data">
    <div style="margin-bottom:16px;">
      <label style="display:block;font-size:13px;font-weight:500;color:#464555;margin-bottom:6px;">Final Transcript <span style="color:#777587;">(SRT or TXT)</span></label>
      <div style="border:2px dashed #c7c4d8;border-radius:6px;padding:20px;text-align:center;background:#fcf2eb;position:relative;">
        <svg width="20" height="20" fill="none" stroke="#777587" stroke-width="1.5" viewBox="0 0 24 24" style="margin:0 auto 6px;"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
        <p style="font-size:13px;color:#464555;margin:0 0 4px;font-family:'Inter',sans-serif;">Drop file here or click to browse</p>
        <input type="file" name="transcript" accept=".srt,.txt" style="position:absolute;inset:0;width:100%;height:100%;opacity:0;cursor:pointer;" id="dist-transcript-input">
        <span id="dist-transcript-name" style="font-size:12px;color:#777587;font-family:'Inter',sans-serif;">No file chosen</span>
      </div>
    </div>
    <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center;">
      <button type="submit" style="background:#ba4b1d;color:#fff;border:none;padding:10px 20px;border-radius:6px;font-family:'Inter',sans-serif;font-size:14px;font-weight:600;cursor:pointer;">Upload &amp; Continue →</button>
      <% if (session?.transcript_v2) { %>
        <button type="submit" name="use_editorial_output" value="1" style="background:none;border:1px solid #ba4b1d;color:#ba4b1d;padding:10px 16px;border-radius:6px;font-family:'Inter',sans-serif;font-size:13px;font-weight:500;cursor:pointer;">Use Content Editor output</button>
      <% } %>
    </div>
  </form>
</div>

<% } else { %>
<!-- ── Final transcript ready: per-output generation + review ───────────────── -->

<%
  const anyContent = outputs.some(function(o) { return episode[o.dbColumn]; });
%>

<!-- Status pipeline + bulk actions -->
<div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:20px;">
  <div style="display:flex;gap:6px;flex-wrap:wrap;">
    <% outputs.forEach(function(o) {
      const hasContent = !!episode[o.dbColumn];
      const approved = !!episode[o.approvedColumn];
      let c, bg, dot;
      if (!hasContent)      { c='#a8a4b8'; bg='#f4f1fa'; dot='#d8d4e4'; }
      else if (approved)    { c='#065f46'; bg='#d1fae5'; dot='#059669'; }
      else                  { c='#777587'; bg='#f0e6e0'; dot='#c7c4d8'; }
    %>
      <span data-host="<%= o.host || '' %>" class="status-pill" style="display:inline-flex;align-items:center;gap:5px;font-size:12px;font-weight:500;color:<%= c %>;background:<%= bg %>;padding:4px 10px;border-radius:99px;">
        <span style="width:7px;height:7px;border-radius:50%;background:<%= dot %>;flex-shrink:0;"></span>
        <%= o.tabLabel %>
      </span>
    <% }); %>
  </div>
  <div style="display:flex;gap:8px;flex-wrap:wrap;">
    <form action="/recordings/<%= recording.id %>/distribution/generate" method="POST">
      <input type="hidden" name="host_name" class="host-name-field" value="Rahul">
      <button type="submit" onclick="showLoading();" style="display:flex;align-items:center;gap:6px;background:<%= anyContent ? 'none' : '#ba4b1d' %>;border:<%= anyContent ? '1px solid #c7c4d8' : 'none' %>;color:<%= anyContent ? '#464555' : '#fff' %>;padding:8px 14px;border-radius:6px;font-family:'Inter',sans-serif;font-size:13px;font-weight:<%= anyContent ? '500' : '600' %>;cursor:pointer;">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        <%= anyContent ? 'Regenerate All' : 'Generate All' %>
      </button>
    </form>
  </div>
</div>

<!-- Tabs (one per output, derived from registry) -->
<div style="border-bottom:1px solid #c7c4d8;margin-bottom:24px;display:flex;gap:4px;overflow-x:auto;">
  <% outputs.forEach(function(o) { %>
    <button onclick="switchTab('<%= o.key %>')" class="tab-btn" id="tab-<%= o.key %>" data-host="<%= o.host || '' %>" style="padding:10px 16px;font-family:'Inter',sans-serif;font-size:13px;font-weight:500;color:#777587;background:none;border:none;cursor:pointer;white-space:nowrap;"><%= o.tabLabel %></button>
  <% }); %>
</div>

<!-- Panels -->
<% outputs.forEach(function(o) {
  const content = episode[o.dbColumn] || '';
  const hasContent = !!episode[o.dbColumn];
  const approved = !!episode[o.approvedColumn];
%>
<div class="tab-panel" id="panel-<%= o.key %>">
  <div style="background:#ffffff;border:1px solid #c7c4d8;border-radius:8px;overflow:hidden;">
    <div style="padding:20px 24px;border-bottom:1px solid #f0e6e0;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;">
      <h2 style="font-family:'Inter',sans-serif;font-size:15px;font-weight:600;color:#1f1b17;margin:0;"><%= o.heading %></h2>
      <% if (hasContent) { %>
        <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
          <span id="status-<%= o.key %>"><% if (approved) { %><%- approvedBadge %><% } else { %><%- draftBadge %><% } %></span>
          <div style="display:flex;align-items:center;gap:6px;">
            <form action="/recordings/<%= recording.id %>/distribution/regenerate/<%= o.key %>" method="POST" style="display:inline-flex;align-items:center;gap:6px;">
              <% if (o.modes) { %>
                <select name="mode" style="padding:4px 8px;border:1px solid #c7c4d8;border-radius:5px;font-family:'Inter',sans-serif;font-size:12px;color:#464555;background:#fff;">
                  <% o.modes.forEach(function(m) { %><option value="<%= m %>"><%= m.charAt(0).toUpperCase() + m.slice(1) %></option><% }); %>
                </select>
              <% } %>
              <% if (o.usesHost) { %><input type="hidden" name="host_name" class="host-name-field" value="Rahul"><% } %>
              <button type="submit" onclick="showLoading();" style="font-size:13px;color:#ba4b1d;background:none;border:none;cursor:pointer;font-weight:500;font-family:'Inter',sans-serif;">Regenerate</button>
            </form>
            <button hx-post="/recordings/<%= recording.id %>/distribution/approve/<%= o.key %>" hx-target="#status-<%= o.key %>" hx-swap="innerHTML" style="background:#ba4b1d;color:#fff;border:none;padding:6px 14px;border-radius:6px;font-family:'Inter',sans-serif;font-size:13px;font-weight:600;cursor:pointer;">Approve</button>
            <button hx-post="/recordings/<%= recording.id %>/distribution/feedback" hx-vals='{"content_type":"<%= o.key %>","rating":"1"}' hx-swap="none" style="background:none;border:1px solid #c7c4d8;padding:4px 10px;border-radius:6px;font-size:14px;cursor:pointer;" title="Good">👍</button>
            <button hx-post="/recordings/<%= recording.id %>/distribution/feedback" hx-vals='{"content_type":"<%= o.key %>","rating":"-1"}' hx-swap="none" style="background:none;border:1px solid #c7c4d8;padding:4px 10px;border-radius:6px;font-size:14px;cursor:pointer;" title="Not good">👎</button>
          </div>
        </div>
      <% } %>
    </div>

    <% if (hasContent) { %>
      <%- include('partials/output-panel', { editUrl: `/recordings/${recording.id}/distribution/edit/${o.key}`, platform: o.key, content: content }) %>
    <% } else { %>
      <!-- Not generated yet: per-output generate -->
      <div style="padding:48px 24px;text-align:center;">
        <div style="width:48px;height:48px;border-radius:12px;background:#fde8d6;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
          <svg width="24" height="24" fill="none" stroke="#ba4b1d" stroke-width="1.5" viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        </div>
        <p style="font-family:'Inter',sans-serif;font-size:14px;color:#777587;margin:0 0 20px;">Not generated yet.</p>
        <form action="/recordings/<%= recording.id %>/distribution/generate/<%= o.key %>" method="POST" style="display:inline-flex;align-items:center;gap:8px;flex-wrap:wrap;justify-content:center;">
          <% if (o.modes) { %>
            <select name="mode" style="padding:6px 10px;border:1px solid #c7c4d8;border-radius:5px;font-family:'Inter',sans-serif;font-size:13px;color:#464555;background:#fff;">
              <% o.modes.forEach(function(m) { %><option value="<%= m %>"><%= m.charAt(0).toUpperCase() + m.slice(1) %></option><% }); %>
            </select>
          <% } %>
          <% if (o.usesHost) { %><input type="hidden" name="host_name" class="host-name-field" value="Rahul"><% } %>
          <button type="submit" onclick="showLoading();" style="display:inline-flex;align-items:center;gap:8px;background:#ba4b1d;color:#fff;border:none;padding:10px 20px;border-radius:6px;font-family:'Inter',sans-serif;font-size:14px;font-weight:600;cursor:pointer;">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            Generate <%= o.tabLabel %>
          </button>
        </form>
      </div>
    <% } %>
  </div>
</div>
<% }); %>

<% } %>

<script>
function switchTab(tab) {
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  const btn = document.getElementById('tab-' + tab);
  const panel = document.getElementById('panel-' + tab);
  if (btn) btn.classList.add('active');
  if (panel) panel.classList.add('active');
}

function showLoading() {
  document.getElementById('loading-overlay').style.display = 'flex';
}

function copyContent(platform) {
  const el = document.getElementById('preview-' + platform);
  if (!el) return;
  navigator.clipboard.writeText(el.textContent).then(() => {
    const btn = el.closest('div')?.querySelector('button');
    if (btn) { const orig = btn.textContent; btn.textContent = 'Copied!'; setTimeout(() => btn.textContent = orig, 1500); }
  });
}

// Show only the active host's personal-X tab/pill (Rahul vs Gautham).
function updateHostTabs(host) {
  const isRahul = host === 'Rahul';
  document.querySelectorAll('[data-host="rahul"]').forEach(el => el.style.display = isRahul ? '' : 'none');
  document.querySelectorAll('[data-host="gautham"]').forEach(el => el.style.display = isRahul ? 'none' : '');
  const active = document.querySelector('.tab-btn.active');
  if (active && active.style.display === 'none') {
    const first = [...document.querySelectorAll('.tab-btn')].find(b => b.style.display !== 'none');
    if (first) switchTab(first.id.replace('tab-', ''));
  }
}

document.querySelectorAll('.host-name-field').forEach(el => {
  el.value = localStorage.getItem('swai_host') || 'Rahul';
});

document.getElementById('dist-transcript-input')?.addEventListener('change', function() {
  document.getElementById('dist-transcript-name').textContent = this.files[0]?.name || 'No file chosen';
});

(function() {
  const host = localStorage.getItem('swai_host') || 'Rahul';
  updateHostTabs(host);
  const firstVisible = [...document.querySelectorAll('.tab-btn')].find(b => b.style.display !== 'none');
  if (firstVisible) switchTab(firstVisible.id.replace('tab-', ''));
})();
</script>

<%- include('partials/foot') %>
