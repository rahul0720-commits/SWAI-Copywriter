    <h2 style="font-family:'Space Grotesk',sans-serif;font-size:18px;font-weight:700;color:#1f1b17;margin:0 0 6px;">Editorial complete</h2>
    <p style="font-family:'Inter',sans-serif;font-size:14px;color:#777587;margin:0;">Pass 1: <%= p1Cuts %> cut<%= p1Cuts!==1?'s':'' %> &nbsp;·&nbsp; Pass 2: <%= p2Cuts %> cut<%= p2Cuts!==1?'s':'' %> &nbsp;·&nbsp; v2 transcript ready</p>
  </div>
  <form action="/episodes/<%= episode.id %>/editorial/send-to-copywriter" method="POST">
    <button type="submit" style="display:inline-flex;align-items:center;gap:8px;background:#ba4b1d;color:#fff;border:none;padding:12px 24px;border-radius:6px;font-family:'Inter',sans-serif;font-size:15px;font-weight:600;cursor:pointer;white-space:nowrap;">
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
      Send to Copywriter
    </button>
  </form>
</div>

<!-- Suggested edits markdown -->
<details style="background:#fff;border:1px solid #c7c4d8;border-radius:8px;padding:0;margin-bottom:16px;" open>
  <summary style="padding:16px 20px;font-family:'Inter',sans-serif;font-size:14px;font-weight:600;color:#464555;cursor:pointer;list-style:none;display:flex;align-items:center;justify-content:space-between;">
    <span style="display:flex;align-items:center;gap:8px;">
      <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
      Suggested edits — copy to share with video editor
    </span>
    <button onclick="event.stopPropagation();copyMarkdown()" style="font-size:12px;font-weight:600;padding:4px 12px;border-radius:5px;background:#ba4b1d;color:#fff;border:none;cursor:pointer;">Copy</button>
  </summary>
  <pre id="suggested-edits-md" style="margin:0;padding:0 20px 20px;font-family:'Space Grotesk',monospace;font-size:12px;color:#464555;white-space:pre-wrap;line-height:1.7;max-height:500px;overflow-y:auto;border-top:1px solid #ece1cd;"><%= suggestedEditsMarkdown %></pre>
</details>

<!-- v2 transcript (collapsed) -->
<details style="background:#fff;border:1px solid #c7c4d8;border-radius:8px;padding:0;">
  <summary style="padding:16px 20px;font-family:'Inter',sans-serif;font-size:14px;font-weight:600;color:#464555;cursor:pointer;list-style:none;display:flex;align-items:center;gap:8px;">
    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
    v2 transcript (final, feeds copywriter)
  </summary>
  <pre style="margin:0;padding:0 20px 20px;font-family:'Space Grotesk',monospace;font-size:12px;color:#464555;white-space:pre-wrap;line-height:1.6;max-height:400px;overflow-y:auto;border-top:1px solid #ece1cd;"><%= session.transcript_v2 %></pre>
</details>

<% } %>


<script>
function playSegment(start, end) {
  const audio = document.getElementById('ep-audio');
  if (!audio) return;
  audio.currentTime = start;
  audio.play();
  const check = setInterval(() => {
    if (audio.currentTime >= end) { audio.pause(); clearInterval(check); }
  }, 200);
  audio.onended = () => clearInterval(check);
}

function copyMarkdown() {
  const el = document.getElementById('suggested-edits-md');
  if (!el) return;
  navigator.clipboard.writeText(el.textContent).then(() => {
    const btn = event.target;
    const orig = btn.textContent;
    btn.textContent = 'Copied!';
    setTimeout(() => btn.textContent = orig, 1500);
  });
}
</script>

