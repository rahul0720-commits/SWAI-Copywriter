<%- include('partials/head', { title: 'Intro Script' }) %>

<!-- Loading overlay -->
<div id="loading-overlay" class="loading-overlay" style="display:none;">
  <div class="spinner"></div>
  <p style="font-family:'Inter',sans-serif;font-size:16px;font-weight:600;color:#1f1b17;margin:0;">Generating intro script…</p>
  <p style="font-family:'Inter',sans-serif;font-size:14px;color:#777587;margin:4px 0 0;">Claude is writing your intro. This takes a few seconds.</p>
</div>

<!-- Back link -->
<div style="margin-bottom:20px;">
  <a href="/" style="display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:500;color:#777587;text-decoration:none;" onmouseover="this.style.color='#ba4b1d'" onmouseout="this.style.color='#777587'">
    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
    All distribution copies
  </a>
</div>

<!-- Episode header + tab strip -->
<div style="margin-bottom:28px;">
  <h1 style="font-family:'Space Grotesk',sans-serif;font-size:24px;font-weight:700;color:#1f1b17;letter-spacing:-0.02em;margin:0 0 4px;"><%= episode.title %></h1>
  <p style="font-family:'Inter',sans-serif;font-size:14px;color:#777587;margin:0 0 20px;">
    <% if (episode.guest_name) { %>with <%= episode.guest_name %> &middot; <% } %>
    <%= new Date(episode.created_at).toLocaleDateString('en-US', { month:'long', day:'numeric', year:'numeric' }) %>
  </p>
  <div style="display:flex;gap:0;border-bottom:2px solid #c7c4d8;">
    <a href="/episodes/<%= episode.id %>/editorial" style="padding:8px 18px;font-family:'Inter',sans-serif;font-size:14px;font-weight:500;color:#777587;text-decoration:none;" onmouseover="this.style.color='#1f1b17'" onmouseout="this.style.color='#777587'">Editorial</a>
    <a href="/episodes/<%= episode.id %>/review" style="padding:8px 18px;font-family:'Inter',sans-serif;font-size:14px;font-weight:500;color:#777587;text-decoration:none;" onmouseover="this.style.color='#1f1b17'" onmouseout="this.style.color='#777587'">Distribution Copy</a>
    <a href="/episodes/<%= episode.id %>/intro" style="padding:8px 18px;font-family:'Inter',sans-serif;font-size:14px;font-weight:600;color:#ba4b1d;text-decoration:none;border-bottom:2px solid #ba4b1d;margin-bottom:-2px;">Intro Script</a>
  </div>
</div>

<% if (error) { %>
<div style="background:#fde8d6;border:1px solid #ba4b1d;border-radius:8px;padding:12px 16px;margin-bottom:20px;font-family:'Inter',sans-serif;font-size:14px;color:#8c3213;">
  <%= error %>
</div>
<% } %>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;align-items:start;">

  <!-- Left: Upload + Generate -->
  <div style="background:#fff;border:1px solid #c7c4d8;border-radius:8px;padding:28px;">
    <h2 style="font-family:'Space Grotesk',sans-serif;font-size:16px;font-weight:700;color:#1f1b17;margin:0 0 6px;">Generate intro script</h2>
    <p style="font-family:'Inter',sans-serif;font-size:13px;color:#777587;margin:0 0 24px;">Upload the raw recording transcript to generate a punchy &lt;100 word intro you can record immediately.</p>

    <form action="/episodes/<%= episode.id %>/intro/generate" method="POST" enctype="multipart/form-data" onsubmit="document.getElementById('loading-overlay').style.display='flex';">
      <div style="margin-bottom:20px;">
        <label style="display:block;font-size:13px;font-weight:600;color:#464555;margin-bottom:8px;">
          Transcript file <span style="font-weight:400;color:#777587;">(.txt or .srt)</span>
        </label>
        <% if (episode.transcript_raw || episode.transcript_clean) { %>
          <p style="font-size:12px;color:#065f46;background:#d1fae5;border-radius:5px;padding:6px 10px;margin:0 0 10px;display:inline-block;">✓ Episode transcript available — or upload a different one below</p><br>
        <% } %>
        <div style="border:2px dashed #c7c4d8;border-radius:6px;padding:20px;text-align:center;background:#fcf2eb;position:relative;" id="drop-zone">
          <svg width="24" height="24" fill="none" stroke="#777587" stroke-width="1.5" viewBox="0 0 24 24" style="margin:0 auto 8px;display:block;"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
          <p style="font-size:13px;color:#464555;margin:0 0 4px;font-family:'Inter',sans-serif;">Drop transcript here or click to browse</p>
          <p style="font-size:12px;color:#777587;margin:0;font-family:'Inter',sans-serif;" id="drop-file-name">No file chosen</p>
          <input type="file" name="transcript" accept=".txt,.srt" style="position:absolute;inset:0;width:100%;height:100%;opacity:0;cursor:pointer;" id="transcript-input" onchange="document.getElementById('drop-file-name').textContent = this.files[0]?.name || 'No file chosen'">
        </div>
        <% if (episode.transcript_raw || episode.transcript_clean) { %>
          <p style="font-size:12px;color:#777587;margin:8px 0 0;font-family:'Inter',sans-serif;">Leave blank to use the existing episode transcript.</p>
        <% } %>
      </div>

      <button type="submit" style="display:flex;align-items:center;gap:8px;background:#ba4b1d;color:#fff;border:none;padding:10px 20px;border-radius:6px;font-family:'Inter',sans-serif;font-size:14px;font-weight:600;cursor:pointer;transition:background 0.15s;" onmouseover="this.style.background='#8c3213'" onmouseout="this.style.background='#ba4b1d'">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        Generate intro script
      </button>
    </form>
  </div>

  <!-- Right: Script output + edit -->
  <div>
    <% if (episode.intro_script) { %>
    <div style="background:#fff;border:1px solid #c7c4d8;border-radius:8px;padding:28px;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
        <h2 style="font-family:'Space Grotesk',sans-serif;font-size:16px;font-weight:700;color:#1f1b17;margin:0;">Intro script</h2>
        <button onclick="copyScript()" style="display:flex;align-items:center;gap:6px;background:none;border:1px solid #c7c4d8;color:#464555;padding:6px 12px;border-radius:6px;font-family:'Inter',sans-serif;font-size:13px;font-weight:500;cursor:pointer;" id="copy-btn" onmouseover="this.style.borderColor='#ba4b1d';this.style.color='#ba4b1d'" onmouseout="this.style.borderColor='#c7c4d8';this.style.color='#464555'">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
          Copy
        </button>
      </div>

      <!-- Word count badge -->
      <%
        const wordCount = episode.intro_script.trim().split(/\s+/).length;
        const wcColor = wordCount <= 100 ? '#059669' : '#92400e';
        const wcBg = wordCount <= 100 ? '#d1fae5' : '#fef3c7';
      %>
      <div style="margin-bottom:16px;">
        <span style="font-size:12px;font-weight:600;color:<%= wcColor %>;background:<%= wcBg %>;padding:3px 10px;border-radius:99px;"><%= wordCount %> words</span>
      </div>

      <!-- Editable script -->
      <form action="/episodes/<%= episode.id %>/intro/save" method="POST">
        <textarea name="intro_script" id="script-text" rows="10" style="width:100%;padding:12px 14px;border:1px solid #c7c4d8;border-radius:6px;font-family:'Inter',sans-serif;font-size:14px;line-height:1.7;color:#1f1b17;background:#fcf2eb;resize:vertical;box-sizing:border-box;"><%= episode.intro_script %></textarea>
        <div style="display:flex;gap:10px;margin-top:12px;">
          <button type="submit" style="background:none;border:1px solid #c7c4d8;color:#464555;padding:8px 16px;border-radius:6px;font-family:'Inter',sans-serif;font-size:13px;font-weight:500;cursor:pointer;" onmouseover="this.style.borderColor='#ba4b1d';this.style.color='#ba4b1d'" onmouseout="this.style.borderColor='#c7c4d8';this.style.color='#464555'">Save edits</button>
        </div>
      </form>
    </div>
    <% } else { %>
    <div style="background:#fff;border:1px dashed #c7c4d8;border-radius:8px;padding:40px;text-align:center;">
      <svg width="32" height="32" fill="none" stroke="#c7c4d8" stroke-width="1.5" viewBox="0 0 24 24" style="margin:0 auto 12px;display:block;"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
      <p style="font-family:'Inter',sans-serif;font-size:14px;color:#777587;margin:0 0 4px;">No intro script yet</p>
      <p style="font-family:'Inter',sans-serif;font-size:13px;color:#c7c4d8;margin:0;">Upload a transcript and click Generate.</p>
    </div>
    <% } %>
  </div>

</div>

<script>
function copyScript() {
  const text = document.getElementById('script-text')?.value;
  if (!text) return;
  navigator.clipboard.writeText(text).then(() => {
    const btn = document.getElementById('copy-btn');
    btn.textContent = '✓ Copied';
    setTimeout(() => {
      btn.innerHTML = '<svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg> Copy';
    }, 2000);
  });
}
</script>

<%- include('partials/foot') %>
