  </main>

<script>
  // Active nav highlighting
  const path = window.location.pathname;
  document.querySelectorAll('[data-nav]').forEach(el => {
    const nav = el.dataset.nav;
    if (nav === 'distribution' && (path === '/distribution' || path.endsWith('/distribution'))) {
      el.classList.add('active');
    } else if (nav === 'post-production' && (path === '/recordings' || (path.startsWith('/recordings/') && !path.endsWith('/distribution')))) {
      el.classList.add('active');
    } else if (nav === 'history' && path.startsWith('/history')) {
      el.classList.add('active');
    } else if (nav === 'prompts' && path.startsWith('/settings/prompts')) {
      el.classList.add('active');
    } else if (nav === 'editorial-settings' && path === '/settings/editorial') {
      el.classList.add('active');
    }
  });
</script>
</body>
</html>
