<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - SWAI Copywriter</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/htmx.org@2.0.4"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            ui: ['Inter', 'sans-serif'],
            content: ['Inter', 'sans-serif'],
            mono: ['Space Grotesk', 'monospace'],
          },
          colors: {
            surface: {
              DEFAULT: '#ffffff',
              dim: '#e2d8d2',
              low: '#fcf2eb',
              mid: '#f6ece6',
              high: '#f0e6e0',
              highest: '#eae1da',
            },
            ink: {
              DEFAULT: '#1f1b17',
              muted: '#464555',
            },
            border: {
              DEFAULT: '#c7c4d8',
              strong: '#777587',
            },
            primary: {
              DEFAULT: '#ba4b1d',
              dark: '#8c3213',
              light: '#fde8d6',
            },
            warm: '#ece1cd',
          },
        }
      }
    }
  </script>
  <style>
    body { font-family: 'Inter', sans-serif; }
    .font-content { font-family: 'Inter', sans-serif; }
    .font-mono-custom { font-family: 'Space Grotesk', monospace; }

    .htmx-indicator { display: none; }
    .htmx-request .htmx-indicator { display: inline-block; }
    .htmx-request.htmx-indicator { display: inline-block; }

    .tab-btn { border-bottom: 2px solid transparent; }
    .tab-btn.active { border-color: #ba4b1d; color: #ba4b1d; }
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    .nav-link { display: flex; align-items: center; gap: 10px; padding: 8px 12px; border-radius: 6px; font-size: 14px; font-weight: 500; color: #464555; text-decoration: none; transition: background 0.15s, color 0.15s; }
    .nav-link:hover { background: #f0e6e0; color: #1f1b17; }
    .nav-link.active { background: #fde8d6; color: #8c3213; }

    input[type="text"], input[type="date"], input[type="file"], textarea, select {
      font-family: 'Inter', sans-serif;
    }
    textarea.prompt-input { font-family: 'Space Grotesk', monospace; }

    .status-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; flex-shrink: 0; }
    .loading-overlay { position: fixed; inset: 0; background: rgba(255,248,245,0.92); z-index: 9999; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 16px; }
    .spinner { width: 40px; height: 40px; border: 3px solid #fde8d6; border-top-color: #ba4b1d; border-radius: 50%; animation: spin 0.8s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }

    :focus-visible { outline: 2px solid #ba4b1d; outline-offset: 2px; }
    input:focus, textarea:focus { border-color: #ba4b1d !important; box-shadow: 0 0 0 3px rgba(196,87,26,0.12); outline: none; }

    /* Top nav */
    .topnav-link { display:inline-flex; align-items:center; padding:8px 14px; border-radius:6px; font-family:'Inter',sans-serif; font-size:14px; font-weight:500; color:#464555; text-decoration:none; white-space:nowrap; transition:background 0.12s, color 0.12s; }
    .topnav-link:hover { background:#f6ece6; color:#1f1b17; }
    .topnav-link.active { background:#fde8d6; color:#8c3213; font-weight:600; }

    @media (max-width: 860px) {
      #top-nav { display: none !important; }
      #mobile-nav-toggle { display: inline-flex !important; }
      #main-content { padding: 20px 16px !important; }
    }
  </style>
</head>
<body style="background:#ece1cd; color:#1f1b17;" class="min-h-screen">

<!-- Top nav -->
<header style="position:sticky;top:0;z-index:30;background:#ffffff;border-bottom:1px solid #c7c4d8;">
  <div style="max-width:1240px;margin:0 auto;padding:0 24px;display:flex;align-items:center;gap:24px;height:60px;">
    <a href="/recordings" style="text-decoration:none;display:flex;flex-direction:column;flex-shrink:0;line-height:1.15;">
      <span style="font-family:'Inter',sans-serif;font-weight:700;font-size:16px;color:#1f1b17;letter-spacing:-0.01em;">SWAI Copywriter</span>
      <span style="font-size:11px;color:#777587;font-family:'Inter',sans-serif;">Shipping with AI Podcast</span>
    </a>
    <nav id="top-nav" style="display:flex;align-items:center;gap:4px;flex:1;">
      <a href="/recordings" class="topnav-link" data-nav="post-production">Post-production</a>
      <a href="/distribution" class="topnav-link" data-nav="distribution">Distribution</a>
      <a href="/history" class="topnav-link" data-nav="history">History</a>
      <a href="/settings/prompts" class="topnav-link" data-nav="prompts">Taste Prompts</a>
      <a href="/settings/editorial" class="topnav-link" data-nav="editorial-settings">Editorial Settings</a>
    </nav>
    <button id="mobile-nav-toggle" onclick="var m=document.getElementById('mobile-nav');m.style.display=(m.style.display==='flex'?'none':'flex');" style="display:none;background:none;border:none;cursor:pointer;color:#464555;padding:4px;margin-left:auto;" aria-label="Menu">
      <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
  </div>
  <nav id="mobile-nav" style="display:none;flex-direction:column;gap:2px;border-top:1px solid #f0e6e0;padding:8px 16px;">
    <a href="/recordings" class="topnav-link" data-nav="post-production">Post-production</a>
    <a href="/distribution" class="topnav-link" data-nav="distribution">Distribution</a>
    <a href="/history" class="topnav-link" data-nav="history">History</a>
    <a href="/settings/prompts" class="topnav-link" data-nav="prompts">Taste Prompts</a>
    <a href="/settings/editorial" class="topnav-link" data-nav="editorial-settings">Editorial Settings</a>
  </nav>
</header>

<!-- Main content -->
<main id="main-content" style="max-width:1240px;margin:0 auto;padding:32px 24px;">
