<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - SWAI Copywriter</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/htmx.org@2.0.4"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            ui: ['Inter', 'sans-serif'],
            content: ['Inter', 'sans-serif'],
            mono: ['Space Grotesk', 'monospace'],
          },
          colors: {
            surface: {
              DEFAULT: '#ffffff',
              dim: '#e2d8d2',
              low: '#fcf2eb',
              mid: '#f6ece6',
              high: '#f0e6e0',
              highest: '#eae1da',
            },
            ink: {
              DEFAULT: '#1f1b17',
              muted: '#464555',
            },
            border: {
              DEFAULT: '#c7c4d8',
              strong: '#777587',
            },
            primary: {
              DEFAULT: '#ba4b1d',
              dark: '#8c3213',
              light: '#fde8d6',
            },
            warm: '#ece1cd',
          },
        }
      }
    }
  </script>
  <style>
    body { font-family: 'Inter', sans-serif; }
    .font-content { font-family: 'Inter', sans-serif; }
    .font-mono-custom { font-family: 'Space Grotesk', monospace; }

    .htmx-indicator { display: none; }
    .htmx-request .htmx-indicator { display: inline-block; }
    .htmx-request.htmx-indicator { display: inline-block; }

    .tab-btn { border-bottom: 2px solid transparent; }
    .tab-btn.active { border-color: #ba4b1d; color: #ba4b1d; }
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    .nav-link { display: flex; align-items: center; gap: 10px; padding: 8px 12px; border-radius: 6px; font-size: 14px; font-weight: 500; color: #464555; text-decoration: none; transition: background 0.15s, color 0.15s; }
    .nav-link:hover { background: #f0e6e0; color: #1f1b17; }
    .nav-link.active { background: #fde8d6; color: #8c3213; }

    input[type="text"], input[type="date"], input[type="file"], textarea, select {
      font-family: 'Inter', sans-serif;
    }
    textarea.prompt-input { font-family: 'Space Grotesk', monospace; }

    .status-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; flex-shrink: 0; }
    .loading-overlay { position: fixed; inset: 0; background: rgba(255,248,245,0.92); z-index: 9999; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 16px; }
    .spinner { width: 40px; height: 40px; border: 3px solid #fde8d6; border-top-color: #ba4b1d; border-radius: 50%; animation: spin 0.8s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }

    :focus-visible { outline: 2px solid #ba4b1d; outline-offset: 2px; }
    input:focus, textarea:focus { border-color: #ba4b1d !important; box-shadow: 0 0 0 3px rgba(196,87,26,0.12); outline: none; }

    /* Mobile sidebar overlay */
    #sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 40; }
    #sidebar-overlay.open { display: block; }
    #app-sidebar { transition: transform 0.2s ease; }

    @media (max-width: 768px) {
      #app-sidebar {
        position: fixed !important;
        top: 0; left: 0; bottom: 0;
        z-index: 50;
        transform: translateX(-100%);
      }
      #app-sidebar.open { transform: translateX(0); }
      #mobile-header { display: flex !important; }
      #main-content { padding: 16px !important; }
    }
  </style>
</head>
<body style="background:#ece1cd; color:#1f1b17;" class="min-h-screen">

<!-- Mobile header bar -->
<div id="mobile-header" style="display:none;position:sticky;top:0;z-index:30;background:#ffffff;border-bottom:1px solid #c7c4d8;padding:12px 16px;align-items:center;justify-content:space-between;gap:12px;">
  <button onclick="openSidebar()" style="background:none;border:none;cursor:pointer;color:#464555;padding:4px;display:flex;align-items:center;" aria-label="Open menu">
    <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
  </button>
  <a href="/recordings" style="text-decoration:none;font-family:'Inter',sans-serif;font-weight:700;font-size:15px;color:#1f1b17;letter-spacing:-0.01em;">SWAI Copywriter</a>
  <div style="width:30px;"></div>
</div>

<!-- Sidebar overlay (mobile) -->
<div id="sidebar-overlay" onclick="closeSidebar()"></div>

<div class="flex min-h-screen">

  <!-- Sidebar -->
  <aside id="app-sidebar" style="width:260px; background:#ffffff; border-right:1px solid #c7c4d8; flex-shrink:0; display:flex; flex-direction:column; position:sticky; top:0; height:100vh; overflow-y:auto;">
    <!-- Logo -->
    <div style="padding:20px 20px 14px;display:flex;align-items:center;justify-content:space-between;">
      <a href="/recordings" style="text-decoration:none;">
        <div style="font-family:'Inter',sans-serif; font-weight:700; font-size:16px; color:#1f1b17; letter-spacing:-0.01em;">SWAI Copywriter</div>
        <div style="font-size:11px; color:#777587; margin-top:2px; font-family:'Inter',sans-serif;">Shipping with AI Podcast</div>
      </a>
      <!-- Close button (mobile only) -->
      <button onclick="closeSidebar()" style="background:none;border:none;cursor:pointer;color:#777587;padding:4px;display:none;" id="sidebar-close-btn" aria-label="Close menu">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </div>

    <div style="height:1px; background:#c7c4d8; margin:0 20px;"></div>

    <!-- Nav -->
    <nav style="padding:14px 12px; flex:1;">
      <div style="font-size:11px; font-weight:600; color:#777587; letter-spacing:0.08em; text-transform:uppercase; padding:0 12px; margin-bottom:8px;">Workspace</div>
      <a href="/recordings" class="nav-link" data-nav="recordings">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
        Recordings
      </a>
      <a href="/settings/prompts" class="nav-link" data-nav="prompts" style="margin-top:2px;">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 20h9M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
        Taste Prompts
      </a>
      <a href="/settings/editorial" class="nav-link" data-nav="editorial-settings" style="margin-top:2px;">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
        Editorial Settings
      </a>
    </nav>

    <!-- Host setting -->
    <div style="padding:12px 20px 16px;border-top:1px solid #c7c4d8;">
      <div style="font-size:11px;font-weight:600;color:#777587;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:10px;">Host</div>
      <div style="display:flex;gap:6px;">
        <button id="host-btn-Rahul" onclick="setHost('Rahul')" style="flex:1;padding:6px 10px;border-radius:6px;font-family:'Inter',sans-serif;font-size:13px;font-weight:500;border:1px solid #c7c4d8;cursor:pointer;transition:all 0.1s;">Rahul</button>
        <button id="host-btn-Gautham" onclick="setHost('Gautham')" style="flex:1;padding:6px 10px;border-radius:6px;font-family:'Inter',sans-serif;font-size:13px;font-weight:500;border:1px solid #c7c4d8;cursor:pointer;transition:all 0.1s;">Gautham</button>
      </div>
    </div>
    <script>
    (function() {
      function applyHostButtons(name) {
        ['Rahul','Gautham'].forEach(function(h) {
          var btn = document.getElementById('host-btn-' + h);
          if (!btn) return;
          if (h === name) {
            btn.style.background = '#fde8d6'; btn.style.color = '#8c3213'; btn.style.borderColor = '#ba4b1d';
          } else {
            btn.style.background = ''; btn.style.color = '#464555'; btn.style.borderColor = '#c7c4d8';
          }
        });
      }
      window.setHost = function(name) {
        localStorage.setItem('swai_host', name);
        applyHostButtons(name);
        if (typeof updateHostTabs === 'function') updateHostTabs(name);
      };
      var _h = localStorage.getItem('swai_host') || 'Rahul';
      document.addEventListener('DOMContentLoaded', function() { applyHostButtons(_h); });
    })();
    </script>

    <!-- Social status -->
    <% if (typeof twitterConnected !== 'undefined') { %>
    <div style="padding:16px 20px; border-top:1px solid #c7c4d8;">
      <div style="font-size:11px; font-weight:600; color:#777587; letter-spacing:0.08em; text-transform:uppercase; margin-bottom:10px;">Connections</div>
      <div style="display:flex; flex-direction:column; gap:8px;">
        <div style="display:flex; align-items:center; justify-content:space-between;">
          <span style="font-size:13px; color:#464555; font-weight:500;">Twitter / X</span>
          <% if (twitterConnected) { %>
            <span style="display:flex;align-items:center;gap:5px;font-size:12px;color:#059669;background:#d1fae5;padding:2px 8px;border-radius:99px;font-weight:500;">
              <span class="status-dot" style="background:#059669;"></span>Connected
            </span>
          <% } else { %>
            <a href="/auth/twitter" style="font-size:12px;color:#ba4b1d;text-decoration:none;font-weight:500;padding:2px 8px;border:1px solid #ba4b1d;border-radius:6px;">Connect</a>
          <% } %>
        </div>
        <div style="display:flex; align-items:center; justify-content:space-between;">
          <span style="font-size:13px; color:#464555; font-weight:500;">LinkedIn</span>
          <% if (linkedinConnected) { %>
            <span style="display:flex;align-items:center;gap:5px;font-size:12px;color:#059669;background:#d1fae5;padding:2px 8px;border-radius:99px;font-weight:500;">
              <span class="status-dot" style="background:#059669;"></span>Connected
            </span>
          <% } else { %>
            <a href="/auth/linkedin" style="font-size:12px;color:#ba4b1d;text-decoration:none;font-weight:500;padding:2px 8px;border:1px solid #ba4b1d;border-radius:6px;">Connect</a>
          <% } %>
        </div>
      </div>
    </div>
    <% } %>
  </aside>

  <!-- Main content -->
  <main id="main-content" style="flex:1; padding:40px 48px; overflow-y:auto; min-width:0;">
