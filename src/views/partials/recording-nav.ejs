<%
// Post-production stage tabs for a recording. Params: recording, active ('intro' | 'editorial')
const tabs = [
  { key: 'intro',     name: 'Intro Script',   href: `/recordings/${recording.id}` },
  { key: 'editorial', name: 'Content Editor', href: `/recordings/${recording.id}/editorial` },
];
%>
<div style="display:flex;gap:0;border-bottom:2px solid #c7c4d8;overflow-x:auto;">
  <% tabs.forEach(function(tab) { var isActive = tab.key === active; %>
    <a href="<%= tab.href %>" style="padding:8px 18px;font-family:'Inter',sans-serif;font-size:14px;font-weight:<%= isActive ? '600' : '500' %>;color:<%= isActive ? '#ba4b1d' : '#777587' %>;text-decoration:none;white-space:nowrap;<%= isActive ? 'border-bottom:2px solid #ba4b1d;margin-bottom:-2px;' : '' %>"<% if (!isActive) { %> onmouseover="this.style.color='#1f1b17'" onmouseout="this.style.color='#777587'"<% } %>><%= tab.name %></a>
  <% }); %>
</div>
