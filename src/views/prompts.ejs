<%- include('partials/head', { title: 'Prompts' }) %>

<div style="margin-bottom:32px;">
  <h1 style="font-family:'Space Grotesk',sans-serif;font-size:28px;font-weight:700;color:#1f1b17;letter-spacing:-0.02em;margin:0 0 6px;">Prompt Editor</h1>
  <p style="font-family:'Inter',sans-serif;font-size:15px;color:#777587;margin:0;">Edit the AI prompts Claude uses to generate content. Changes take effect immediately for new generations.</p>
</div>

<% if (saved) { %>
  <div style="display:flex;align-items:center;gap:10px;padding:12px 16px;background:#d1fae5;border:1px solid #a7f3d0;border-radius:6px;margin-bottom:20px;">
    <svg width="16" height="16" fill="none" stroke="#059669" stroke-width="2.5" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>
    <span style="font-family:'Inter',sans-serif;font-size:14px;font-weight:500;color:#065f46;">Prompt saved successfully.</span>
  </div>
<% } %>
<% if (reset) { %>
  <div style="display:flex;align-items:center;gap:10px;padding:12px 16px;background:#dbeafe;border:1px solid #bfdbfe;border-radius:6px;margin-bottom:20px;">
    <svg width="16" height="16" fill="none" stroke="#2563eb" stroke-width="2.5" viewBox="0 0 24 24"><path d="M3 12a9 9 0 1018 0 9 9 0 00-18 0M12 8v4l3 3"/></svg>
    <span style="font-family:'Inter',sans-serif;font-size:14px;font-weight:500;color:#1e40af;">Prompt reset to default.</span>
  </div>
<% } %>

<!-- Tabs -->
<div style="border-bottom:1px solid #c7c4d8;margin-bottom:24px;display:flex;gap:4px;">
  <% prompts.forEach((p, i) => { %>
    <button onclick="switchTab('<%= p.name %>')" id="tab-<%= p.name %>" class="tab-btn <%= i===0 ? 'active' : '' %>" style="display:flex;align-items:center;gap:8px;padding:10px 16px;font-family:'Inter',sans-serif;font-size:13px;font-weight:500;color:#777587;background:none;border:none;cursor:pointer;">
      <%= p.label %>
      <% if (p.isCustom) { %>
        <span style="width:7px;height:7px;border-radius:50%;background:#ba4b1d;flex-shrink:0;" title="Custom prompt active"></span>
      <% } %>
    </button>
  <% }) %>
</div>

<!-- Panels -->
<% prompts.forEach((p, i) => { %>
  <div id="panel-<%= p.name %>" class="tab-panel <%= i===0 ? 'active' : '' %>">
    <div style="background:#ffffff;border:1px solid #c7c4d8;border-radius:8px;overflow:hidden;">

      <!-- Panel header -->
      <div style="padding:20px 24px;border-bottom:1px solid #f0e6e0;display:flex;align-items:center;justify-content:space-between;">
        <div>
          <h2 style="font-family:'Inter',sans-serif;font-size:15px;font-weight:600;color:#1f1b17;margin:0 0 2px;"><%= p.label %></h2>
          <% if (p.isCustom) { %>
            <span style="font-size:12px;font-weight:500;color:#ba4b1d;font-family:'Inter',sans-serif;">Custom prompt active</span>
          <% } else { %>
            <span style="font-size:12px;color:#777587;font-family:'Inter',sans-serif;">Using default prompt</span>
          <% } %>
        </div>
        <% if (p.isCustom) { %>
          <form method="POST" action="/settings/prompts/<%= p.name %>/reset" onsubmit="return confirm('Reset to default prompt?')">
            <button type="submit" style="display:flex;align-items:center;gap:6px;background:none;color:#464555;border:1px solid #c7c4d8;padding:7px 14px;border-radius:6px;font-family:'Inter',sans-serif;font-size:13px;font-weight:500;cursor:pointer;">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 12a9 9 0 1018 0 9 9 0 00-18 0M12 8v4l3 3"/></svg>
              Reset to default
            </button>
          </form>
        <% } %>
      </div>

      <!-- Split: instructions + editor -->
      <div style="display:grid;grid-template-columns:1fr 2fr;min-height:500px;">

        <!-- Instructions panel -->
        <div style="padding:24px;border-right:1px solid #f0e6e0;background:#fcf2eb;">
          <p style="font-size:11px;font-weight:600;color:#777587;letter-spacing:0.06em;text-transform:uppercase;margin:0 0 12px;">Tips</p>
          <ul style="font-family:'Inter',sans-serif;font-size:13px;color:#464555;line-height:1.7;margin:0;padding-left:16px;">
            <li style="margin-bottom:8px;">Be specific about tone, length, and format.</li>
            <li style="margin-bottom:8px;">Use <code style="font-family:'Space Grotesk',monospace;background:#f0e6e0;padding:1px 5px;border-radius:3px;font-size:12px;">{{transcript}}</code> to reference the transcript text.</li>
            <li style="margin-bottom:8px;">Mention the podcast name to ground the content.</li>
            <li>Test changes in the <a href="https://console.anthropic.com/workbench" target="_blank" style="color:#ba4b1d;font-weight:500;">Anthropic Workbench</a> before saving.</li>
          </ul>

          <div style="margin-top:24px;padding:14px;background:#ffffff;border-radius:6px;border:1px solid #c7c4d8;">
            <p style="font-size:11px;font-weight:600;color:#777587;letter-spacing:0.06em;text-transform:uppercase;margin:0 0 8px;">Default prompt</p>
            <div style="max-height:200px;overflow-y:auto;">
              <pre style="font-family:'Space Grotesk',monospace;font-size:11px;color:#464555;white-space:pre-wrap;margin:0;line-height:1.6;"><%= p.defaultContent %></pre>
            </div>
          </div>
        </div>

        <!-- Editor panel -->
        <div style="padding:24px;display:flex;flex-direction:column;">
          <form method="POST" action="/settings/prompts/<%= p.name %>" style="flex:1;display:flex;flex-direction:column;">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
              <p style="font-size:11px;font-weight:600;color:#777587;letter-spacing:0.06em;text-transform:uppercase;margin:0;">Your prompt</p>
              <span id="char-count-<%= p.name %>" style="font-size:12px;color:#777587;font-family:'Inter',sans-serif;"></span>
            </div>
            <textarea
              name="content"
              id="textarea-<%= p.name %>"
              rows="22"
              class="prompt-input"
              oninput="updateCount('<%= p.name %>', this.value)"
              style="flex:1;width:100%;padding:14px;border:1px solid #c7c4d8;border-radius:6px;font-family:'Space Grotesk',monospace;font-size:13px;line-height:1.7;color:#1f1b17;resize:vertical;box-sizing:border-box;background:#fff;"
            ><%= p.content %></textarea>
            <div style="margin-top:14px;display:flex;align-items:center;justify-content:flex-end;">
              <button type="submit" style="background:#ba4b1d;color:#fff;border:none;padding:10px 22px;border-radius:6px;font-family:'Inter',sans-serif;font-size:14px;font-weight:600;cursor:pointer;">Save Prompt</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
<% }) %>

<script>
function switchTab(name) {
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
  document.getElementById('panel-' + name).classList.add('active');
}

function updateCount(name, value) {
  const el = document.getElementById('char-count-' + name);
  if (el) el.textContent = value.length.toLocaleString() + ' chars';
}

// Init char counts and auto-open saved/reset tab
document.querySelectorAll('[id^="textarea-"]').forEach(ta => {
  const name = ta.id.replace('textarea-', '');
  updateCount(name, ta.value);
});

<% if (saved) { %>switchTab('<%= saved %>');<% } %>
<% if (reset) { %>switchTab('<%= reset %>');<% } %>
</script>

<%- include('partials/foot') %>
