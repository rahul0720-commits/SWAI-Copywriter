<%- include('partials/head', { title: title }) %>

<!-- Loading overlay -->
<div id="loading-overlay" class="loading-overlay" style="display:none;">
  <div class="spinner"></div>
  <p style="font-family:'Inter',sans-serif;font-size:16px;font-weight:600;color:#1f1b17;margin:0;">Generating intro script…</p>
  <p style="font-family:'Inter',sans-serif;font-size:14px;color:#777587;margin:0;">Claude is writing a punchy <100-word intro. Takes ~10 seconds.</p>
</div>

<!-- Back -->
<div style="margin-bottom:20px;">
  <a href="/recordings" style="display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:500;color:#777587;text-decoration:none;" onmouseover="this.style.color='#ba4b1d'" onmouseout="this.style.color='#777587'">
    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
    All Recordings
  </a>
</div>

<!-- Header + stage tabs -->
<div style="margin-bottom:28px;">
  <h1 style="font-family:'Space Grotesk',sans-serif;font-size:24px;font-weight:700;color:#1f1b17;letter-spacing:-0.02em;margin:0 0 4px;"><%= recording.title %></h1>
  <p style="font-family:'Inter',sans-serif;font-size:14px;color:#777587;margin:0 0 20px;">
    <% if (recording.guest_name) { %>with <%= recording.guest_name %> &middot; <% } %>
    <%= recording.created_at ? new Date(recording.created_at).toLocaleDateString('en-US', { month:'long', day:'numeric', year:'numeric' }) : '' %>
  </p>
  <!-- Stage tabs -->
  <%- include('partials/recording-nav', { recording: recording, active: 'intro' }) %>
</div>

<% if (error) { %>
  <div style="background:#fde8d6;border:1px solid #ba4b1d;border-radius:6px;padding:12px 16px;margin-bottom:20px;font-family:'Inter',sans-serif;font-size:14px;color:#8c3213;">
    <%= error %>
  </div>
<% } %>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;align-items:start;" class="intro-grid">

  <!-- Left: transcript + generate -->
  <div>
    <div style="background:#ffffff;border:1px solid #c7c4d8;border-radius:8px;padding:24px;margin-bottom:16px;">
      <h2 style="font-family:'Inter',sans-serif;font-size:15px;font-weight:600;color:#1f1b17;margin:0 0 16px;">Raw Transcript</h2>

      <% if (recording.raw_transcript) { %>
        <div style="display:flex;align-items:center;gap:8px;padding:10px 14px;background:#d1fae5;border:1px solid #a7f3d0;border-radius:6px;margin-bottom:16px;">
          <svg width="14" height="14" fill="none" stroke="#065f46" stroke-width="2.5" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>
          <span style="font-family:'Inter',sans-serif;font-size:13px;color:#065f46;font-weight:500;">Transcript loaded</span>
        </div>
      <% } else { %>
        <p style="font-family:'Inter',sans-serif;font-size:13px;color:#777587;margin:0 0 16px;">Upload the raw (unedited) transcript to generate the intro script.</p>
      <% } %>

      <form action="/recordings/<%= recording.id %>/intro/upload-transcript" method="POST" enctype="multipart/form-data">
        <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
          <input type="file" name="transcript" accept=".txt,.srt" style="font-size:13px;font-family:'Inter',sans-serif;color:#464555;flex:1;min-width:0;">
          <button type="submit" style="background:none;border:1px solid #c7c4d8;color:#464555;padding:7px 14px;border-radius:6px;font-family:'Inter',sans-serif;font-size:13px;cursor:pointer;white-space:nowrap;"><%= recording.raw_transcript ? 'Replace' : 'Upload' %></button>
        </div>
      </form>
    </div>

    <form action="/recordings/<%= recording.id %>/intro/generate" method="POST" enctype="multipart/form-data" onsubmit="document.getElementById('loading-overlay').style.display='flex';">
      <button type="submit" style="width:100%;display:flex;align-items:center;justify-content:center;gap:8px;background:#ba4b1d;color:#fff;border:none;padding:12px 20px;border-radius:6px;font-family:'Inter',sans-serif;font-size:14px;font-weight:600;cursor:pointer;">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        <%= recording.intro_script ? 'Regenerate Intro Script' : 'Generate Intro Script' %>
      </button>
    </form>

    <!-- Feedback on intro script -->
    <% if (recording.intro_script) { %>
      <div style="margin-top:16px;display:flex;align-items:center;gap:10px;">
        <span style="font-family:'Inter',sans-serif;font-size:13px;color:#777587;">Was this useful?</span>
        <form action="/recordings/<%= recording.id %>/feedback" method="POST" style="display:inline;">
          <input type="hidden" name="content_type" value="intro-script">
          <input type="hidden" name="rating" value="1">
          <button type="submit" hx-post="/recordings/<%= recording.id %>/feedback" hx-vals='{"content_type":"intro-script","rating":"1"}' hx-swap="none" style="background:none;border:1px solid #c7c4d8;padding:5px 12px;border-radius:6px;font-size:14px;cursor:pointer;color:#464555;" title="Thumbs up">👍</button>
        </form>
        <form action="/recordings/<%= recording.id %>/feedback" method="POST" style="display:inline;">
          <input type="hidden" name="content_type" value="intro-script">
          <input type="hidden" name="rating" value="-1">
          <button type="submit" hx-post="/recordings/<%= recording.id %>/feedback" hx-vals='{"content_type":"intro-script","rating":"-1"}' hx-swap="none" style="background:none;border:1px solid #c7c4d8;padding:5px 12px;border-radius:6px;font-size:14px;cursor:pointer;color:#464555;" title="Thumbs down">👎</button>
        </form>
      </div>
    <% } %>

    <!-- Delete recording -->
    <div style="margin-top:24px;padding-top:20px;border-top:1px solid #f0e6e0;">
      <form action="/recordings/<%= recording.id %>/delete" method="POST" onsubmit="return confirm('Delete this recording and all its data?')">
        <button type="submit" style="display:inline-flex;align-items:center;gap:6px;background:none;border:1px solid #c7c4d8;color:#777587;padding:7px 14px;border-radius:6px;font-family:'Inter',sans-serif;font-size:13px;cursor:pointer;">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6M9 6V4h6v2"/></svg>
          Delete Recording
        </button>
      </form>
    </div>
  </div>

  <!-- Right: generated script -->
  <div>
    <div style="background:#ffffff;border:1px solid #c7c4d8;border-radius:8px;overflow:hidden;">
      <div style="padding:16px 20px;border-bottom:1px solid #f0e6e0;display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap;">
        <h2 style="font-family:'Inter',sans-serif;font-size:15px;font-weight:600;color:#1f1b17;margin:0;">Generated Intro Script</h2>
        <% if (recording.intro_script) { %>
          <%
            const wordCount = recording.intro_script.trim().split(/\s+/).length;
            const wcColor = wordCount <= 100 ? '#065f46' : '#92400e';
            const wcBg = wordCount <= 100 ? '#d1fae5' : '#fef3c7';
          %>
          <span style="font-size:12px;font-weight:600;padding:3px 10px;border-radius:99px;color:<%= wcColor %>;background:<%= wcBg %>;">
            <%= wordCount %> words
          </span>
        <% } %>
      </div>

      <% if (recording.intro_script) { %>
        <div style="padding:20px;border-bottom:1px solid #f0e6e0;">
          <div id="intro-preview" style="font-family:'Inter',sans-serif;font-size:14px;line-height:1.7;color:#1f1b17;white-space:pre-wrap;"><%= recording.intro_script %></div>
        </div>
        <div style="padding:16px 20px;display:flex;align-items:center;gap:10px;">
          <button onclick="copyIntro()" style="display:inline-flex;align-items:center;gap:6px;background:#f0e6e0;color:#8c3213;border:none;padding:7px 14px;border-radius:6px;font-family:'Inter',sans-serif;font-size:13px;font-weight:600;cursor:pointer;">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
            Copy
          </button>
          <button onclick="toggleEdit()" id="edit-toggle-btn" style="display:inline-flex;align-items:center;gap:6px;background:none;border:1px solid #c7c4d8;color:#464555;padding:7px 14px;border-radius:6px;font-family:'Inter',sans-serif;font-size:13px;cursor:pointer;">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 20h9M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            Edit
          </button>
        </div>

        <!-- Edit form (hidden by default) -->
        <div id="edit-panel" style="display:none;padding:0 20px 20px;">
          <form action="/recordings/<%= recording.id %>/intro/save" method="POST">
            <textarea name="intro_script" id="intro-textarea" rows="8" style="width:100%;padding:12px;border:1px solid #c7c4d8;border-radius:6px;font-family:'Inter',sans-serif;font-size:14px;line-height:1.7;color:#1f1b17;resize:vertical;box-sizing:border-box;" oninput="updateWordCount(this.value)"><%= recording.intro_script %></textarea>
            <div style="display:flex;align-items:center;justify-content:space-between;margin-top:10px;gap:10px;flex-wrap:wrap;">
              <span id="edit-word-count" style="font-size:12px;color:#777587;font-family:'Inter',sans-serif;"></span>
              <button type="submit" style="background:#ba4b1d;color:#fff;border:none;padding:8px 16px;border-radius:6px;font-family:'Inter',sans-serif;font-size:13px;font-weight:600;cursor:pointer;">Save Changes</button>
            </div>
          </form>
        </div>

      <% } else { %>
        <div style="padding:48px 24px;text-align:center;">
          <svg width="32" height="32" fill="none" stroke="#c7c4d8" stroke-width="1.5" viewBox="0 0 24 24" style="margin:0 auto 12px;"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          <p style="font-family:'Inter',sans-serif;font-size:14px;color:#777587;margin:0;">Generate an intro script using the button on the left.</p>
        </div>
      <% } %>
    </div>
  </div>
</div>

<style>
@media (max-width: 768px) {
  .intro-grid { grid-template-columns: 1fr !important; }
}
</style>

<script>
function copyIntro() {
  const el = document.getElementById('intro-preview');
  if (!el) return;
  navigator.clipboard.writeText(el.textContent).then(() => {
    const btns = el.closest('.card')?.querySelectorAll('button') || document.querySelectorAll('button');
    // find copy button
    const btn = [...document.querySelectorAll('button')].find(b => b.textContent.trim() === 'Copy');
    if (btn) { const orig = btn.textContent; btn.textContent = 'Copied!'; setTimeout(() => btn.textContent = orig, 1500); }
  });
}

function toggleEdit() {
  const panel = document.getElementById('edit-panel');
  const btn = document.getElementById('edit-toggle-btn');
  const isHidden = panel.style.display === 'none';
  panel.style.display = isHidden ? 'block' : 'none';
  btn.textContent = isHidden ? '✕ Cancel' : '✎ Edit';
  if (isHidden) {
    const ta = document.getElementById('intro-textarea');
    if (ta) updateWordCount(ta.value);
  }
}

function updateWordCount(val) {
  const count = val.trim() ? val.trim().split(/\s+/).length : 0;
  const el = document.getElementById('edit-word-count');
  if (el) {
    el.textContent = count + ' words';
    el.style.color = count <= 100 ? '#065f46' : '#92400e';
  }
}
</script>

<%- include('partials/foot') %>
