<script>
// Helper: render a preview+edit panel (called via <%- outputPanel(...) %>)
</script>

<%
function outputPanel(epId, platform, content) {
  const safe = (content || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  const safeRaw = (content || '').replace(/`/g, '&#96;');
  return `
    <div style="display:grid;grid-template-columns:1fr 1fr;min-height:420px;">
      <div style="padding:24px;border-right:1px solid #f0e6e0;display:flex;flex-direction:column;gap:12px;">
        <div style="display:flex;align-items:center;justify-content:space-between;">
          <p style="font-size:11px;font-weight:600;color:#777587;letter-spacing:0.06em;text-transform:uppercase;margin:0;">Preview</p>
          <button onclick="copyContent('${platform}')" style="display:inline-flex;align-items:center;gap:6px;background:#f0e6e0;color:#8c3213;border:none;padding:5px 12px;border-radius:6px;font-family:'Inter',sans-serif;font-size:12px;font-weight:600;cursor:pointer;">
            <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
            Copy
          </button>
        </div>
        <div id="preview-${platform}" style="font-family:'Space Grotesk',monospace;font-size:13px;line-height:1.7;color:#1f1b17;white-space:pre-wrap;overflow-y:auto;max-height:520px;flex:1;">${safe}</div>
      </div>
      <div style="padding:24px;display:flex;flex-direction:column;gap:12px;">
        <p style="font-size:11px;font-weight:600;color:#777587;letter-spacing:0.06em;text-transform:uppercase;margin:0;">Edit</p>
        <form hx-post="/episodes/${epId}/edit/${platform}" hx-target="#status-${platform}" hx-swap="innerHTML" style="flex:1;display:flex;flex-direction:column;gap:10px;">
          <textarea name="content" rows="22" style="flex:1;width:100%;padding:12px;border:1px solid #c7c4d8;border-radius:6px;font-family:'Space Grotesk',monospace;font-size:13px;line-height:1.7;color:#1f1b17;resize:vertical;box-sizing:border-box;">${safe}</textarea>
          <button type="submit" style="align-self:flex-end;background:#ba4b1d;color:#fff;border:none;padding:8px 16px;border-radius:6px;font-family:'Inter',sans-serif;font-size:13px;font-weight:600;cursor:pointer;">Save Changes</button>
        </form>
      </div>
    </div>
  `;
}
%>

<script>
function switchTab(tab) {
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  const btn = document.getElementById('tab-' + tab);
  const panel = document.getElementById('panel-' + tab);
  if (btn) btn.classList.add('active');
  if (panel) panel.classList.add('active');
}

function showLoading() {
  document.getElementById('loading-overlay').style.display = 'flex';
}

function copyContent(platform) {
  const el = document.getElementById('preview-' + platform);
  if (!el) return;
  navigator.clipboard.writeText(el.textContent).then(() => {
    const btn = el.closest('[style]').querySelector('button');
    if (btn) { const orig = btn.textContent; btn.textContent = 'Copied!'; setTimeout(() => btn.textContent = orig, 1500); }
  });
}

function updateHostTabs(host) {
  const isRahul = host === 'Rahul';
  const rahulTab   = document.getElementById('tab-rahul-x');
  const gauthamTab = document.getElementById('tab-gautham-x');
  if (!rahulTab) return;

  rahulTab.style.display   = isRahul ? '' : 'none';
  gauthamTab.style.display = isRahul ? 'none' : '';

  // If currently active tab is being hidden, switch to the other
  const active = document.querySelector('.tab-btn.active');
  if (active && active.style.display === 'none') {
    switchTab(isRahul ? 'rahul-x' : 'gautham-x');
  }
}

// Populate host_name fields from localStorage
document.querySelectorAll('.host-name-field').forEach(el => {
  el.value = localStorage.getItem('swai_host') || 'Rahul';
});

// Init tabs based on host setting
(function() {
  const host = localStorage.getItem('swai_host') || 'Rahul';
  updateHostTabs(host);
  // Set first visible tab active
  const firstVisible = host === 'Rahul' ? 'rahul-x' : 'gautham-x';
  switchTab(firstVisible);
})();
</script>

