<script>
function switchTab(tab) {
  document.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active'); });
  document.querySelectorAll('.tab-panel').forEach(function(p) { p.classList.remove('active'); });
  var btn = document.getElementById('tab-' + tab);
  var panel = document.getElementById('panel-' + tab);
  if (btn) btn.classList.add('active');
  if (panel) panel.classList.add('active');
}

function showLoading() {
  document.getElementById('loading-overlay').style.display = 'flex';
}

function copyContent(platform) {
  var el = document.getElementById('preview-' + platform);
  if (!el) return;
  navigator.clipboard.writeText(el.textContent).then(function() {
    var btns = el.parentElement.querySelectorAll('button');
    var btn = btns[0];
    if (btn) { var orig = btn.textContent; btn.textContent = 'Copied!'; setTimeout(function() { btn.textContent = orig; }, 1500); }
  });
}

function updateHostTabs(host) {
  var isRahul = host === 'Rahul';
  var rahulTab   = document.getElementById('tab-rahul-x');
  var gauthamTab = document.getElementById('tab-gautham-x');
  if (!rahulTab) return;
  rahulTab.style.display   = isRahul ? '' : 'none';
  gauthamTab.style.display = isRahul ? 'none' : '';
  var active = document.querySelector('.tab-btn.active');
  if (active && active.style.display === 'none') {
    switchTab(isRahul ? 'rahul-x' : 'gautham-x');
  }
}

document.querySelectorAll('.host-name-field').forEach(function(el) {
  el.value = localStorage.getItem('swai_host') || 'Rahul';
});

(function() {
  var host = localStorage.getItem('swai_host') || 'Rahul';
  updateHostTabs(host);
  switchTab(host === 'Rahul' ? 'rahul-x' : 'gautham-x');
})();
</script>

