<%- include('partials/head', { title: 'Review: ' + episode.title }) %>

<!-- Loading overlay (shown during Generate) -->
<div id="loading-overlay" class="loading-overlay" style="display:none;">
  <div class="spinner"></div>
  <p style="font-family:'Inter',sans-serif;font-size:16px;font-weight:600;color:#1f1b17;margin:0;">Generating content…</p>
  <p style="font-family:'Inter',sans-serif;font-size:14px;color:#777587;margin:0;">Claude is writing all 6 outputs. This takes 30–60 seconds.</p>
</div>

<!-- Back -->
<div style="margin-bottom:24px;">
  <a href="/" style="display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:500;color:#777587;text-decoration:none;" onmouseover="this.style.color='#ba4b1d'" onmouseout="this.style.color='#777587'">
    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
    All episodes
  </a>
</div>

<!-- Episode header -->
<div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:28px;gap:16px;">
  <div>
    <h1 style="font-family:'Space Grotesk',sans-serif;font-size:24px;font-weight:700;color:#1f1b17;letter-spacing:-0.02em;margin:0 0 4px;"><%= episode.title %></h1>
    <p style="font-family:'Inter',sans-serif;font-size:14px;color:#777587;margin:0;">
      <% if (episode.guest_name) { %>with <%= episode.guest_name %> &middot; <% } %>
      <%= new Date(episode.created_at).toLocaleDateString('en-US', { month:'long', day:'numeric', year:'numeric' }) %>
    </p>
  </div>
  <div style="display:flex;gap:10px;flex-shrink:0;">
    <% if (!episode.rahul_x) { %>
      <form action="/episodes/<%= episode.id %>/generate" method="POST" id="generate-form">
        <input type="hidden" name="host_name" id="generate-host-name" value="Rahul">
        <button type="submit" onclick="document.getElementById('generate-host-name').value = localStorage.getItem('swai_host') || 'Rahul'; showLoading();" style="display:flex;align-items:center;gap:8px;background:#ba4b1d;color:#fff;border:none;padding:10px 20px;border-radius:6px;font-family:'Inter',sans-serif;font-size:14px;font-weight:600;cursor:pointer;">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          Generate All Content
        </button>
      </form>
    <% } %>
    <form action="/episodes/<%= episode.id %>/delete" method="POST" onsubmit="return confirm('Delete this episode?')">
      <button type="submit" style="background:none;border:1px solid #c7c4d8;color:#777587;padding:10px 14px;border-radius:6px;font-family:'Inter',sans-serif;font-size:14px;cursor:pointer;" title="Delete episode">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6M9 6V4h6v2"/></svg>
      </button>
    </form>
  </div>
</div>

<% if (episode.rahul_x) { %>

<!-- Status pipeline -->
<div style="display:flex;gap:6px;margin-bottom:24px;padding:16px;background:#ffffff;border:1px solid #c7c4d8;border-radius:8px;align-items:center;flex-wrap:wrap;">
  <span style="font-size:12px;font-weight:600;color:#777587;letter-spacing:0.04em;text-transform:uppercase;margin-right:8px;">Content status</span>
  <%
    const statuses = [
      { label: "Rahul X",    approved: episode.rahul_x_approved },
      { label: "Gautham X",  approved: episode.gautham_x_approved },
      { label: "Brand X",    approved: episode.brand_x_approved },
      { label: "X Article",  approved: episode.x_article_approved },
      { label: "LinkedIn",   approved: episode.linkedin_approved },
      { label: "YouTube",    approved: episode.youtube_approved },
    ];
  %>
  <% statuses.forEach(s => { %>
    <% const c = s.approved ? '#065f46' : '#777587', bg = s.approved ? '#d1fae5' : '#f0e6e0', dot = s.approved ? '#059669' : '#c7c4d8'; %>
    <span style="display:inline-flex;align-items:center;gap:5px;font-size:12px;font-weight:500;color:<%= c %>;background:<%= bg %>;padding:4px 10px;border-radius:99px;">
      <span style="width:7px;height:7px;border-radius:50%;background:<%= dot %>;flex-shrink:0;"></span>
      <%= s.label %>
    </span>
  <% }) %>
</div>

<!-- Tabs -->
<div style="border-bottom:1px solid #c7c4d8;margin-bottom:24px;display:flex;gap:4px;" id="tab-bar">
  <button onclick="switchTab('rahul-x')" class="tab-btn" id="tab-rahul-x" style="padding:10px 16px;font-family:'Inter',sans-serif;font-size:13px;font-weight:500;color:#777587;background:none;border:none;cursor:pointer;white-space:nowrap;">Rahul X</button>
  <button onclick="switchTab('gautham-x')" class="tab-btn" id="tab-gautham-x" style="padding:10px 16px;font-family:'Inter',sans-serif;font-size:13px;font-weight:500;color:#777587;background:none;border:none;cursor:pointer;white-space:nowrap;">Gautham X</button>
  <button onclick="switchTab('brand-x')" class="tab-btn" id="tab-brand-x" style="padding:10px 16px;font-family:'Inter',sans-serif;font-size:13px;font-weight:500;color:#777587;background:none;border:none;cursor:pointer;white-space:nowrap;">Brand X</button>
  <button onclick="switchTab('x-article')" class="tab-btn" id="tab-x-article" style="padding:10px 16px;font-family:'Inter',sans-serif;font-size:13px;font-weight:500;color:#777587;background:none;border:none;cursor:pointer;white-space:nowrap;">X Article</button>
  <button onclick="switchTab('linkedin')" class="tab-btn" id="tab-linkedin" style="padding:10px 16px;font-family:'Inter',sans-serif;font-size:13px;font-weight:500;color:#777587;background:none;border:none;cursor:pointer;white-space:nowrap;">LinkedIn</button>
  <button onclick="switchTab('youtube')" class="tab-btn" id="tab-youtube" style="padding:10px 16px;font-family:'Inter',sans-serif;font-size:13px;font-weight:500;color:#777587;background:none;border:none;cursor:pointer;white-space:nowrap;">YouTube</button>
</div>

<!-- ── Rahul X ── -->
