  <div style="background:#ffffff;border:1px solid #c7c4d8;border-radius:8px;overflow:hidden;">
    <div style="padding:20px 24px;border-bottom:1px solid #f0e6e0;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;">
      <h2 style="font-family:'Inter',sans-serif;font-size:15px;font-weight:600;color:#1f1b17;margin:0;">Rahul's Personal X</h2>
      <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
        <span id="status-rahul-x"><%- episode.rahul_x_approved ? `<span style="display:inline-flex;align-items:center;gap:5px;font-size:12px;font-weight:500;color:#065f46;background:#d1fae5;padding:4px 10px;border-radius:99px;"><span style="width:7px;height:7px;border-radius:50%;background:#059669;flex-shrink:0;"></span>Approved</span>` : `<span style="display:inline-flex;align-items:center;gap:5px;font-size:12px;font-weight:500;color:#777587;background:#f0e6e0;padding:4px 10px;border-radius:99px;"><span style="width:7px;height:7px;border-radius:50%;background:#c7c4d8;flex-shrink:0;"></span>Draft</span>` %></span>
