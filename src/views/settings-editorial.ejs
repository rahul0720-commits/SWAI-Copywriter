<%- include('partials/head', { title: title }) %>

<div style="max-width:720px;">

  <!-- Page header -->
  <div style="margin-bottom:28px;">
    <h1 style="font-family:'Inter',sans-serif;font-size:24px;font-weight:700;color:#1f1b17;letter-spacing:-0.02em;margin:0 0 4px;">Content Editor</h1>
    <p style="font-family:'Inter',sans-serif;font-size:14px;color:#777587;margin:0;">These guidelines are injected into every editorial pass prompt. Edit them to reflect your show's editorial taste.</p>
  </div>

  <!-- Show criteria editor -->
  <div style="background:#ffffff;border:1px solid #c7c4d8;border-radius:8px;padding:24px;margin-bottom:24px;">
    <h2 style="font-family:'Inter',sans-serif;font-size:15px;font-weight:600;color:#1f1b17;margin:0 0 14px;">Show criteria</h2>
    <form action="/settings/editorial" method="POST">
      <textarea name="criteria_text" rows="10" style="width:100%;padding:12px;border:1px solid #c7c4d8;border-radius:6px;font-family:'Space Grotesk',monospace;font-size:13px;color:#1f1b17;background:#fff;box-sizing:border-box;resize:vertical;line-height:1.6;"><%= criteria %></textarea>
      <div style="margin-top:12px;display:flex;gap:10px;">
        <button type="submit" style="background:#ba4b1d;color:#fff;border:none;padding:9px 20px;border-radius:6px;font-family:'Inter',sans-serif;font-size:14px;font-weight:600;cursor:pointer;">Save criteria</button>
      </div>
    </form>
  </div>

  <!-- Keep list -->
  <div style="background:#ffffff;border:1px solid #c7c4d8;border-radius:8px;padding:24px;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
      <div>
        <h2 style="font-family:'Inter',sans-serif;font-size:15px;font-weight:600;color:#1f1b17;margin:0 0 2px;">Keep list</h2>
        <p style="font-family:'Inter',sans-serif;font-size:13px;color:#777587;margin:0;">Patterns you've rejected during Pass 2 review. Injected into future Pass 2 prompts to suppress re-flagging.</p>
      </div>
      <span style="font-size:12px;font-weight:600;color:#777587;background:#fcf2eb;padding:3px 10px;border-radius:12px;"><%= keepList.length %> entries</span>
    </div>

    <% if (keepList.length === 0) { %>
      <p style="font-family:'Inter',sans-serif;font-size:14px;color:#c7c4d8;margin:0;padding:20px 0;text-align:center;">No entries yet — they'll appear here as you reject flags with reasons during editorial review.</p>
    <% } else { %>
      <div style="display:flex;flex-direction:column;gap:8px;">
        <% keepList.forEach(entry => { %>
          <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:16px;padding:12px 14px;background:#fcf2eb;border:1px solid #fde8d6;border-radius:6px;">
            <div style="flex:1;min-width:0;">
              <p style="font-family:'Space Grotesk',monospace;font-size:12px;color:#1f1b17;margin:0 0 4px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">"<%= entry.pattern %>"</p>
              <p style="font-family:'Inter',sans-serif;font-size:12px;color:#777587;margin:0;"><%= entry.reason %></p>
            </div>
            <form action="/settings/editorial/keep-list/delete" method="POST" style="flex-shrink:0;">
              <input type="hidden" name="id" value="<%= entry.id %>">
              <button type="submit" style="background:none;border:none;cursor:pointer;color:#c7c4d8;padding:2px;" onmouseover="this.style.color='#ba1a1a'" onmouseout="this.style.color='#c7c4d8'" title="Remove">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>
              </button>
            </form>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>

</div>

<%- include('partials/foot') %>
